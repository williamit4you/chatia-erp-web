generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  SUPER_ADMIN
  TENANT_ADMIN
  TENANT_USER
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  cnpj      String   @unique
  iaToken   String?
  erpToken  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  users        User[]
  chatSessions ChatSession[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String?
  
  role      RoleName @default(TENANT_USER)
  
  tenantId  String?
  tenant    Tenant?   @relation(fields: [tenantId], references: [id])

  queryCount Int      @default(0)

  chatSessions ChatSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatSession {
  id        String   @id @default(uuid())
  title     String?
  
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  messages  ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id            String   @id @default(uuid())
  sessionId     String
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  role          String   // "user", "model", "system"
  content       String   @db.Text

  createdAt     DateTime @default(now())
}

// --- MOCK ERP VIEWS --- 
// In a real environment, these would be Prisma Views targeting external schema
// Mapped as tables here to permit scaffolding & mock seeding

model ErpViewFinanceiro {
  id          String   @id @default(uuid())
  tenantId    String
  department  String
  revenue     Float
  expenses    Float
  netIncome   Float
  date        DateTime

  @@map("erp_view_financeiro")
}

model ErpViewEstoque {
  id            String   @id @default(uuid())
  tenantId      String
  productName   String
  sku           String
  quantity      Int
  reorderPoint  Int
  warehouse     String

  @@map("erp_view_estoque")
}

model ErpViewVendas {
  id            String   @id @default(uuid())
  tenantId      String
  clientName    String
  dealValue     Float
  status        String   // "Won", "Lost", "In Progress"
  closingDate   DateTime

  @@map("erp_view_vendas")
}

model ErpViewProducao {
  id            String   @id @default(uuid())
  tenantId      String
  orderNumber   String
  status        String
  oeeScore      Float
  dueDate       DateTime

  @@map("erp_view_producao")
}

model ErpViewRH {
  id            String   @id @default(uuid())
  tenantId      String
  employeeCount Int
  totalPayroll  Float
  absenteeism   Float
  month         DateTime

  @@map("erp_view_rh")
}
